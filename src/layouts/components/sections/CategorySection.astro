---
import RecipeCard from '../ui/RecipeCard.astro';
import { getSinglePage } from "@/lib/contentParser.astro";

interface Props {
  title: string;
  category: string;
}

const { title, category } = Astro.props;

const allPosts = await getSinglePage("posts");
const displayRecipes = allPosts
  .filter((p) => p.data.image && p.data.categories?.includes(category))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4)
  .map((p) => ({
    title: p.data.title,
    href: `/blog/${p.id}`,
    image: p.data.image as string,
  }));
---
<section class="cat-section">
  <h2 class="section-heading">{title}</h2>
  <div class="recipe-grid">
    {displayRecipes.map(r => <RecipeCard recipe={r} />)}
  </div>
  <div class="see-more">
    <a href={`/categories/${category}`}>See more {title} →</a>
  </div>
  <hr class="section-divider" />
</section>

<style>
  .cat-section {
    padding: 50px 24px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .section-heading {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 400;
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
    color: #2a2a2a;
  }
  .section-heading::after {
    content: '';
    flex: 1;
    height: 1px;
    background: currentColor;
    opacity: 0.2;
  }
  .recipe-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .see-more {
    text-align: right;
    margin-top: 12px;
    font-size: 0.85rem;
  }
  .see-more a {
    text-decoration: underline;
    text-underline-offset: 3px;
    color: #3a6b4f;
  }
  .section-divider {
    border: none;
    border-top: 2px dashed #ddd;
    margin-top: 40px;
  }
  @media (max-width: 768px) {
    .recipe-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
