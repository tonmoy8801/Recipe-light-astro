---
import RecipeCard from '../ui/RecipeCard.astro';
import { getSinglePage } from "@/lib/contentParser.astro";

const allPosts = await getSinglePage("posts");
const recipes = allPosts
  .filter((p) => p.data.image)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4)
  .map((p) => ({
    title: p.data.title,
    href: `/blog/${p.id}`,
    image: p.data.image as string,
  }));
---
<section class="trending-section">
  <h2 class="section-heading">Trending Recipes</h2>
  <div class="recipe-grid">
    {recipes.map(r => <RecipeCard recipe={r} />)}
  </div>
</section>

<style>
  .trending-section {
    padding: 50px 24px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .section-heading {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 400;
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
    color: var(--color-text);
  }
  .section-heading::after {
    content: '';
    flex: 1;
    height: 1px;
    background: currentColor;
    opacity: 0.2;
  }
  .recipe-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  @media (max-width: 900px) {
    .recipe-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 500px) {
    .recipe-grid { grid-template-columns: 1fr; }
  }
</style>
